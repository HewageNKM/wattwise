{
  "productName": "WattWise",
  "version": "1.0.0",
  "identifier": "com.wattwise.energy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WattWise",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "scripts/wattwise.service",
      "scripts/wattwise-ctl.sh"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ],
        "files": {
          "/usr/lib/systemd/system/wattwise.service": "scripts/wattwise.service",
          "/usr/bin/wattwise-ctl": "scripts/wattwise-ctl.sh"
        }
      }
    }
  }
}
