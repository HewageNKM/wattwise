[Unit]
Description=Zenith Energy daemon
After=network.target
Conflicts=power-profiles-daemon.service tlp.service
Before=power-profiles-daemon.service tlp.service

[Service]
Type=simple
ExecStart=stdbuf -oL /usr/bin/zenith-energy --daemon
Restart=always
# Run as root to allow hardware sysfs writes
User=root
StandardOutput=append:/var/log/zenith-energy.log
StandardError=append:/var/log/zenith-energy.log

[Install]
WantedBy=multi-user.target
